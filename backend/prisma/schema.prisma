generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  memberships ProjectMember[]
  tasks       Task[]    @relation("AssignedTasks")
  
  // Missing Relations Added
  createdTasks    Task[]    @relation("CreatedTasks")
  createdProjects Project[] @relation("CreatedProjects")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  members ProjectMember[]
  tasks   Task[]

  // Missing Relation Added
  creator User @relation("CreatedProjects", fields: [createdBy], references: [id])
}

model ProjectMember {
  id        String @id @default(uuid())
  userId    String
  projectId String
  role      Role

  // Cascade Deletes Added
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum Role {
  ADMIN
  MEMBER
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority
  dueDate     DateTime?

  projectId   String
  assignedTo  String? // Allowed to be null via SetNull
  createdBy   String? // Allowed to be null via SetNull

  // Cascade and SetNull Deletes Added
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("AssignedTasks", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User?   @relation("CreatedTasks", fields: [createdBy], references: [id], onDelete: SetNull)

  // Indexes for Performance
  @@index([projectId])
  @@index([assignedTo])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}
